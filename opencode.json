{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "java": {
      "extensions": ["java"],
      "disabled": false,
      "initialization": {
        "settings": {
          "java": {
            "configuration": {
              "maven": {
                "enabled": true
              }
            },
            "completion": {
              "guessMethodArguments": true
            },
            "signatureHelp": {
              "enabled": true
            },
            "format": {
              "enabled": false
            }
          }
        }
      }
    }
  }
}
